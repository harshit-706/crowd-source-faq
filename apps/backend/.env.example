# ─────────────────────────────────────────────────────────────────────────────
# YAKSHA FAQ PORTAL — Environment Variables
# Copy to .env or .env.local and fill in every value marked with <...>.
# Server will NOT start without at least one AI API key configured.
# ─────────────────────────────────────────────────────────────────────────────

PORT=6767
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# https://cloud.mongodb.com → Cluster → Connect → Connect your application
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.z3cgb58.mongodb.net/?appName=Cluster0

# ── JWT & Session Authentication ───────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# Optional: Dedicated secret for refresh token signing (defaults to JWT_SECRET)
JWT_REFRESH_SECRET=

# Optional: Access token expiration time (e.g. 15m, 1h, 7d — defaults to 15m)
JWT_EXPIRES_IN=15m

# v1.68 — H1: dedicated AES-GCM master key (replaces JWT_SECRET
# for encrypting Zoom tokens, TOTP secrets, etc.). Rotate
# independently of JWT signing. Generate with: openssl rand -hex 32
# When unset, falls back to JWT_SECRET (backwards compat).
ENCRYPTION_MASTER_KEY=

# v1.68 — Optional: HuggingFace Inference API key for embedding
# generation. When set, embeddings.ts routes through the HF
# Inference API for mxbai-embed-large-v1 (no 1.2GB local
# ONNX download). When unset, falls back to the in-process
# @huggingface/transformers pipeline.
# Get a key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# v1.68 — H1: dedicated HMAC secret for OAuth state signing.
# Rotate independently of JWT signing. Generate with: openssl rand -hex 32
# When unset, falls back to JWT_SECRET (backwards compat).
OAUTH_STATE_SECRET=

# ── Redis (optional — enables cross-instance cache) ───────────────────────────
# https://console.upstash.com → Create Redis Database → REST API
REDIS_URL=https://<your-db>.upstash.io
REDIS_TOKEN=<your-token>

# BullMQ TCP URL (optional — required for OCR & document queue worker)
REDIS_TCP_URL=redis://localhost:6379

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=https://<key>@sentry.io/<project>

# ── Zoom OAuth & Webhooks ──────────────────────────────────────────────────────
# https://marketplace.zoom.us → Create User-managed OAuth app
# Required scopes: recording:read, meeting:read:admin
# OAuth redirect:
#   Dev:  http://localhost:6767/api/zoom/auth/callback
#   Prod: https://yaksha-faq-backend.vercel.app/api/zoom/auth/callback
ZOOM_CLIENT_ID=<your-zoom-oauth-client-id>
ZOOM_CLIENT_SECRET=<your-zoom-oauth-client-secret>
# OAuth redirect URI — must match exactly what's in your Zoom App settings
ZOOM_REDIRECT_URI=http://localhost:6767/api/zoom/auth/callback
# Comma-separated regexes — matching meeting topics are skipped
ZOOM_TOPIC_BLACKLIST=
# Zoom Webhook Verification Token (Required in production for verifying webhook payloads)
ZOOM_WEBHOOK_SECRET_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS — duplicate question detection
# At least ONE must be set. Server refuses to start without one.
# Priority (first configured key wins): Anthropic → OpenAI → Grok → Gemini → MiniMax → Custom
# ─────────────────────────────────────────────────────────────────────────────
#
# ANTHROPIC CLAUDE (recommended)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional: custom endpoint URL for Anthropic API
ANTHROPIC_BASE_URL=

# OPENAI GPT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: custom endpoint URL for OpenAI API
OPENAI_BASE_URL=

# XAI GROK
# https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-3
# Optional: custom endpoint URL for xAI API
XAI_BASE_URL=

# GOOGLE GEMINI
# https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Optional: custom endpoint URL for Gemini API (defaults to Generative Language endpoint)
GEMINI_BASE_URL=

# MINIMAX TEXT — supports custom vLLM endpoint
# https://platform.minimax.io → Token Plan → API Key
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.io/v1

# CUSTOM PROVIDER (vLLM, Ollama, etc.)
CUSTOM_API_KEY=
CUSTOM_MODEL=
CUSTOM_BASE_URL=http://localhost:11434/v1

# ALTERNATIVE AI KEYS (used for fallback extraction or welcome package generation)
GROK_API_KEY=
GROQ_API_KEY=

# ── AI Pipeline Overrides ──────────────────────────────────────────────────────
# Per-pipeline AI provider + model. If unset, falls back to the first configured
# global provider (ANTHROPIC > OPENAI > XAI > MINIMAX > GEMINI).
#
# Providers: anthropic | openai | xai | minimax | gemini | custom
# Models:    any model the provider supports (e.g. claude-3-5-sonnet-latest, gpt-4o-mini,
#            grok-3, MiniMax-Text-01)
#
# FAQ audit pipeline
FAQ_AUDIT_PROVIDER=anthropic
FAQ_AUDIT_MODEL=claude-3-5-sonnet-latest
#
# Auto-answer pipeline
AUTO_ANSWER_PROVIDER=anthropic
AUTO_ANSWER_MODEL=claude-3-5-sonnet-latest

# ── Unanswered Question Escalation ────────────────────────────────────────────
UNANSWERED_ESCALATION_DAYS=7
UNANSWERED_ESCALATION_CHECK_MINUTES=60

# ── Cloudinary (image uploads, LEGACY — being phased out) ──────────────────
# Cloud name + API key + API secret. The /api/upload/sign endpoint signs a
# timestamped payload so the browser can upload directly without exposing
# the API secret. Profile pictures and post attachments both flow through
# this. The folder keeps uploads grouped under `yaksha/`.
# https://console.cloudinary.com → Dashboard
# v1.71 — Image uploads now default to GCS (see below). Cloudinary vars
# remain here so existing signed uploads keep working until the migration
# script has copied all DB rows to GCS.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=yaksha

# ── Google Cloud Storage (image uploads, NEW) ───────────────────────────────
# The /api/upload/sign endpoint returns a V4-signed PUT URL on this bucket.
# The browser uploads directly to GCS — the file bytes never traverse the
# backend. `GCS_PUBLIC_HOST` is the CDN in front of Cloud Run (e.g. the
# Cloud CDN / load balancer hostname serving the img-transform service).
#
# Auth: in production on Cloud Run, the instance service account is used
# implicitly (no env var needed). For local dev, set
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# or run `gcloud auth application-default login`.
#
# Production checklist (do these on GCP, NOT in this env file):
#   1. gsutil mb gs://yaksha-media                          # create bucket
#   2. gsutil cors set cors.json gs://yaksha-media          # browser PUT CORS
#   3. Deploy img-transform Cloud Run service (Sharp + Express)
#   4. Put Cloud CDN in front, set Vary: Accept for f_auto
#   5. DNS: media.mydomain.com → Cloud CDN
GCS_BUCKET=
GCS_PUBLIC_HOST=media.mydomain.com
# Comma-separated subfolders the browser can request for signed uploads.
GCS_ALLOWED_SUBFOLDERS=avatar,posts

# ── Document & Knowledge Pipeline ─────────────────────────────────────────────
# Search count threshold to automatically promote a document insight to a public FAQ
DOCUMENT_INSIGHT_AUTO_PROMOTE_THRESHOLD=3

# ── Discord Bot & Administrative Config ────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_ADMIN_USER_IDS=
DISCORD_NOTIFICATION_CHANNEL_ID=
DISCORD_PUBLIC_CHANNEL_ID=
INTERNAL_API_KEY=

# Public URL used by Discord Bot for invite links and api references (grows from CLIENT_URL)
PUBLIC_URL=http://localhost:6767
# Public base URL used for controlled registration invite links
PUBLIC_BASE_URL=

# Channel ID for logging admin audit events
ADMIN_DISCORD_LOG_CHANNEL=

# Logging webhook URL (logs ALERT/ERROR level events to Discord)
DISCORD_WEBHOOK_URL=

# Passphrase required to change backend configuration and thresholds via Discord Admin Config command/modals.
# Falling back to "adminpassphrase" in development. Required in production.
DISCORD_ADMIN_PASSPHRASE=adminpassphrase
ADMIN_DISCORD_PASSPHRASE=adminpassphrase

# Optional: Override the bcrypt cost factor for admin passphrase hashing (Default: 12 in production, 4 in unit tests)
ADMIN_BCRYPT_COST=12

# ── Local Development Tunnels (run.sh only) ───────────────────────────────────
# Optional: ngrok authentication token to automatically expose local port 6767 to the internet
NGROK_AUTH_TOKEN=
