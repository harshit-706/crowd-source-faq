MONGODB_URI=mongodb_connection_string_here
JWT_SECRET=jwt_se...here
JWT_EXPIRES_IN=7d
PORT=6767
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── OpenAI (required for semantic search embeddings) ──────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Model for embedding generation:
#   text-embedding-3-small  → 1536-dim, $0.02/1M tokens (recommended default)
#   text-embedding-3-large  → 3072-dim, $0.13/1M tokens (higher accuracy)
#   text-embedding-ada-002  → 1536-dim, legacy (use only if you need backward compat)
EMBEDDING_MODEL=text-embedding-3-small
# After changing EMBEDDING_MODEL, run: npm run backfill:embeddings
# Then update the numDimensions in your MongoDB Atlas vector index to match:
#   text-embedding-3-small → 1536 | text-embedding-3-large → 3072
